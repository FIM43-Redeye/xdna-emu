 }
 
+/*
+ * Send a per-context message via the hwctx's user mailbox channel and wait
+ * for the response. Used for opcodes that are semantically scoped to a
+ * single hwctx (e.g., AIE_RW_ACCESS), so a hung firmware response only
+ * destroys that hwctx's channel rather than cascading to the device-wide
+ * mgmt_chann.
+ *
+ * Caller must NOT hold ndev->aie2_lock; the user channel has its own
+ * internal locking.
+ */
+static int aie2_send_ctx_msg_wait(struct amdxdna_ctx *hwctx,
+				  struct xdna_mailbox_msg *msg)
+{
+	struct amdxdna_dev *xdna = hwctx->client->xdna;
+	struct mailbox_channel *chann = hwctx->priv->mbox_chann;
+	struct xdna_notify *hdl = msg->handle;
+	int ret;
+
+	if (!chann)
+		return -ENODEV;
+
+	ret = xdna_send_msg_wait(xdna, chann, msg);
+	if (ret == -ETIME) {
+		xdna_mailbox_stop_channel(chann);
+		xdna_mailbox_destroy_channel(chann);
+		hwctx->priv->mbox_chann = NULL;
+	}
+
+	if (!ret && *hdl->status != AIE2_STATUS_SUCCESS) {
+		XDNA_ERR(xdna, "command opcode 0x%x failed, status 0x%x",
+			 msg->opcode, *hdl->data);
+		ret = -EINVAL;
+	}
+
+	return ret;
+}
