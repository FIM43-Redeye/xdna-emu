# BDD Enumeration Tool for AIE2 instruction encoding analysis
#
# Downloads and builds CUDD 3.0.0 (BSD-licensed BDD library), then compiles
# bdd_enum against it. CUDD provides the DDDMP loader for .ena files and
# the BDD traversal primitives we need.
#
# Usage:
#   make              Build everything (downloads CUDD on first run)
#   make clean        Remove our build artifacts
#   make distclean    Remove everything including CUDD source

CUDD_VERSION  := 3.0.0
CUDD_DIR      := cudd-$(CUDD_VERSION)
CUDD_TARBALL  := cudd-release.tar.gz
CUDD_URL      := https://github.com/ivmai/cudd/archive/refs/heads/release.tar.gz
CUDD_LIB      := $(CUDD_DIR)/cudd/.libs/libcudd.a

BUILD_DIR     := build
TARGET        := $(BUILD_DIR)/bdd_enum

CC            := gcc
CFLAGS        := -O2 -Wall -Wextra -Wno-unused-parameter -std=c11
INCLUDES      := -I$(CUDD_DIR)/cudd -I$(CUDD_DIR)/dddmp -I$(CUDD_DIR)/mtr \
                 -I$(CUDD_DIR)/epd -I$(CUDD_DIR)/st -I$(CUDD_DIR)/util \
                 -I$(CUDD_DIR)
LDFLAGS       := -lm

SRCS          := bdd_enum.c bdd_analysis.c bdd_output.c
OBJS          := $(SRCS:%.c=$(BUILD_DIR)/%.o)

# ---- Top-level targets ----

.PHONY: all clean distclean

all: $(TARGET)

$(TARGET): $(OBJS) $(CUDD_LIB) | $(BUILD_DIR)
	$(CC) $(CFLAGS) -o $@ $(OBJS) $(CUDD_LIB) $(LDFLAGS)

# Object files depend on CUDD_LIB because config.h is generated by configure,
# which runs as part of the CUDD build.
$(BUILD_DIR)/%.o: %.c bdd_analysis.h bdd_output.h $(CUDD_LIB) | $(BUILD_DIR)
	$(CC) $(CFLAGS) $(INCLUDES) -c -o $@ $<

$(BUILD_DIR):
	mkdir -p $(BUILD_DIR)

# ---- CUDD download and build ----

$(CUDD_TARBALL):
	@echo "Downloading CUDD $(CUDD_VERSION)..."
	curl -fSL -o $@ $(CUDD_URL)

$(CUDD_DIR): $(CUDD_TARBALL)
	@echo "Extracting CUDD..."
	tar xzf $(CUDD_TARBALL)
	mv cudd-release $(CUDD_DIR)

$(CUDD_LIB): $(CUDD_DIR)
	@echo "Building CUDD $(CUDD_VERSION) (this takes a minute)..."
	cd $(CUDD_DIR) && autoreconf -fi 2>/dev/null || true
	cd $(CUDD_DIR) && ./configure --enable-dddmp --disable-shared --quiet
	nice -n 19 $(MAKE) -C $(CUDD_DIR) -j$$(nproc) --quiet

# ---- Cleanup ----

clean:
	rm -rf $(BUILD_DIR)

distclean: clean
	rm -rf $(CUDD_DIR) $(CUDD_TARBALL)
