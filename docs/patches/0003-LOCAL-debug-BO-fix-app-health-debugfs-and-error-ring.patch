 	amdxdna_mgmt_buff_free(dma_hdl);
 	return ret;
diff --git a/src/driver/amdxdna/aie2_error.c b/src/driver/amdxdna/aie2_error.c
index 5f7d773..8c7ce30 100644
--- a/src/driver/amdxdna/aie2_error.c
+++ b/src/driver/amdxdna/aie2_error.c
