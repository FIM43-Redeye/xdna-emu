 src/driver/amdxdna/aie2_debugfs.c  | 52 ++++++++++++------
 src/driver/amdxdna/aie2_error.c    | 84 ++++++++++++++++--------------
 src/driver/amdxdna/aie2_pci.c      | 20 +++++--
 src/driver/amdxdna/aie4_error.c    | 75 +++++++++++++++-----------
 src/driver/amdxdna/aie4_pci.c      | 20 +++++--
 src/driver/amdxdna/amdxdna_error.h |  6 ++-
 src/driver/amdxdna/ve2_debug.c     |  7 ++-
 src/driver/amdxdna/ve2_mgmt.c      | 22 +++++---
 9 files changed, 180 insertions(+), 110 deletions(-)

