 #include <linux/container_of.h>
+#include <linux/delay.h>
+#include <linux/pci.h>
 
 #include "amdxdna_drm.h"
 #include "aie2_pci.h"
@@ -35,17 +37,143 @@ static bool aie2_tdr_detect(struct aie2_tdr *tdr)
 	return aie2_rq_is_all_context_stuck(rq);
 }
 
+/*
+ * Perform a Secondary Bus Reset on the parent bridge to reset the NPU.
+ *
+ * This tears down the firmware stack, toggles the SBR bit on the upstream
+ * bridge's Bridge Control register, waits for the device to come back, then
+ * rebuilds the firmware stack from scratch.
+ *
+ * Caller must hold xdna->dev_lock.
+ */
+static int aie2_tdr_bus_reset(struct aie2_tdr *tdr)
+{
+	struct amdxdna_dev *xdna = tdr_to_xdna(tdr);
+	struct pci_dev *pdev = to_pci_dev(xdna->ddev.dev);
+	struct pci_dev *bridge;
+	u16 bridge_ctl;
+	u16 vendor_id;
+	int ret;
+
+	bridge = pci_upstream_bridge(pdev);
+	if (!bridge) {
+		XDNA_ERR(xdna, "No upstream bridge found for SBR");
+		return -ENODEV;
+	}
+
+	XDNA_WARN(xdna, "Performing Secondary Bus Reset via bridge %s",
+		  pci_name(bridge));
+
+	/* Save PCI config space -- SBR clears BARs and other settings */
+	pci_save_state(pdev);
+
+	/* Tear down firmware and hardware state */
+	aie2_hw_stop(xdna);
+
+	/* Assert SBR on the bridge */
+	pci_read_config_word(bridge, PCI_BRIDGE_CONTROL, &bridge_ctl);
+	bridge_ctl |= PCI_BRIDGE_CTL_BUS_RESET;
+	pci_write_config_word(bridge, PCI_BRIDGE_CONTROL, bridge_ctl);
+
+	/* Hold reset asserted for at least 2ms (PCI spec minimum is 1ms) */
+	usleep_range(2000, 5000);
+
+	/* Deassert SBR */
+	bridge_ctl &= ~PCI_BRIDGE_CTL_BUS_RESET;
+	pci_write_config_word(bridge, PCI_BRIDGE_CONTROL, bridge_ctl);
+
+	/* Wait for link to retrain and device to settle */
+	msleep(1000);
+
+	/* Verify device is accessible after reset */
+	pci_read_config_word(pdev, PCI_VENDOR_ID, &vendor_id);
+	if (vendor_id == (u16)~0) {
+		XDNA_ERR(xdna, "Device not accessible after SBR");
+		return -ENODEV;
+	}
+
+	/* Restore PCI config space (BARs, command register, etc.) */
+	pci_restore_state(pdev);
+
+	/* Rebuild firmware and hardware state */
+	ret = aie2_hw_start(xdna);
+	if (ret) {
+		XDNA_ERR(xdna, "Failed to restart hardware after SBR, ret %d", ret);
+		return ret;
+	}
+
+	XDNA_INFO(xdna, "Secondary Bus Reset completed successfully");
+	return 0;
+}
+
+/*
+ * TDR recovery with escalation.
+ *
+ * Escalation model:
+ *   counter 1  -> Soft recovery (stop/restart contexts)
+ *   counter 2  -> Secondary Bus Reset via upstream bridge
+ *   counter 3+ -> Device declared unrecoverable, TDR stopped
+ *
+ * The counter resets to 0 whenever the device resumes making progress
+ * (handled in aie2_tdr_work).
+ *
+ * Uses manual mutex_lock/unlock instead of guard(mutex) so we can call
+ * timer_delete_sync() in the SBR path without scope/lifetime issues.
+ */
 static void aie2_tdr_recover(struct aie2_tdr *tdr, bool dump_only)
 {
 	struct amdxdna_dev *xdna = tdr_to_xdna(tdr);
 	struct aie2_ctx_rq *rq = &xdna->dev_handle->ctx_rq;
 
-	guard(mutex)(&xdna->dev_lock);
+	mutex_lock(&xdna->dev_lock);
 	aie2_rq_dump_all(rq);
-	if (dump_only)
+
+	if (dump_only) {
+		mutex_unlock(&xdna->dev_lock);
+		return;
+	}
+
+	if (tdr->counter == 1) {
+		/* Level 1: Soft recovery -- stop and restart contexts */
+		aie2_rq_stop_all(rq);
+		aie2_rq_restart_all(rq);
+		mutex_unlock(&xdna->dev_lock);
 		return;
-	aie2_rq_stop_all(rq);
-	aie2_rq_restart_all(rq);
+	}
+
+	if (tdr->counter == 2) {
+		int ret;
+
+		/* Level 2: Secondary Bus Reset */
+		aie2_rq_stop_all(rq);
+
+		/* Stop TDR timer to prevent re-entry during reset */
+		timer_delete_sync(&tdr->timer);
+
+		ret = aie2_tdr_bus_reset(tdr);
+		if (ret) {
+			XDNA_ERR(xdna, "SBR failed, device is unrecoverable");
+			tdr->started = 0;
+			mutex_unlock(&xdna->dev_lock);
+			return;
+		}
+
+		/* Restart contexts on fresh hardware */
+		aie2_rq_restart_all(rq);
+
+		/* Re-arm TDR timer to monitor recovery */
+		tdr->timer.expires = jiffies + TDR_TIMEOUT_JIFF;
+		add_timer(&tdr->timer);
+
+		mutex_unlock(&xdna->dev_lock);
+		return;
+	}
+
+	/* Level 3+: Device declared unrecoverable */
+	XDNA_ERR(xdna, "TDR: device unrecoverable, stopping TDR");
+	timer_delete_sync(&tdr->timer);
+	tdr->started = 0;
+	mutex_unlock(&xdna->dev_lock);
 }
 
 static void aie2_tdr_work(struct work_struct *work)
@@ -53,9 +181,17 @@ static void aie2_tdr_work(struct work_struct *work)
 	struct aie2_tdr *tdr = to_tdr(work);
 
 	if (aie2_tdr_detect(tdr)) {
+		tdr->counter++;
 		XDNA_WARN(tdr_to_xdna(tdr),
-			  "Device isn't making progress... Count %d", ++tdr->counter);
+			  "Device isn't making progress... Count %d", tdr->counter);
 		aie2_tdr_recover(tdr, tdr_dump_ctx);
+	} else {
+		/* Device is making progress, reset escalation counter */
+		if (tdr->counter) {
+			XDNA_DBG(tdr_to_xdna(tdr),
+				 "Device resumed progress, TDR counter reset");
+			tdr->counter = 0;
+		}
 	}
 }
 
